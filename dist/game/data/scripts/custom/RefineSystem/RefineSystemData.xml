<?xml version="1.0" encoding="UTF-8"?>
<refineSystem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../xsd/RefineSystemData.xsd">

	<!-- 精煉消耗道具 -->
	<settings refineItemId="57" refineItemCount="1" defaultCharges="35"/>

	<!-- 高級精煉道具：只能洗出 minTier ~ maxTier 的詞，不可用進階自動精煉 -->
	<premiumSettings refineItemId="105804" refineItemCount="1" minTier="1" maxTier="3"/>

	<!-- T 數顏色設定（不設定則預設白色 FFFFFF） -->
	<tierColors>
		<tierColor tier="1" color="8CEA00"/>
		<tierColor tier="2" color="FFFF37"/>
		<tierColor tier="3" color="9F35FF"/>
		<tierColor tier="4" color="2894FF"/>
		<tierColor tier="5" color="E0E0E0"/>
	</tierColors>

	<!-- 特殊裝備精煉次數：每個裝備模板 ID 獨立設定 -->
	<specialCharges>
		<item templateId="120052" charges="50"/>
		<item templateId="120053" charges="50"/>
		<item templateId="120054" charges="50"/>
		<item templateId="120055" charges="50"/>
		<item templateId="120056" charges="50"/>
		<item templateId="120057" charges="50"/>
		<item templateId="120058" charges="50"/>
		<item templateId="120059" charges="50"/>
		<item templateId="120060" charges="50"/>
		<item templateId="120061" charges="50"/>
		<item templateId="120062" charges="50"/>
		<item templateId="120063" charges="50"/>
		<item templateId="120064" charges="50"/>
	</specialCharges>

	<!-- 詞條數量機率：第1條一定有，第2/3/4條各自獨立判斷 -->
	<!-- chance = 出現機率(0~100)，若第N條未出現則後面的也不出現 -->
	<tierChances>
		<tier count="1" chance="100"/>
		<tier count="2" chance="60"/>
		<tier count="3" chance="30"/>
		<tier count="4" chance="5"/>
	</tierChances>

	<!-- 重置精煉次數所需消耗的道具（可設定多種） -->
	<chargeResetCost>
		<item itemId="91663"  count="100000"/>
		<item itemId="103991" count="100000"/>
	</chargeResetCost>

	<!--
	tier 說明：T1 最好，T 數字越大越差。
	  高級精煉道具只從設定的 tier 範圍內抽取。
	  不填 tier（或 tier="0"）表示無 T 數設定，普通/高級都可抽到。

	valueType 說明：
	  PERCENT（預設）：raw/100.0 = % 數字
	  FLAT           ：raw 直接是數值
	  MUL            ：raw/10000.0 = 倍率增量

	range 由小到大排列，tier="5" 最低值區（最差），tier="1" 最高值區（最好）
	-->

	<!-- 10000：最終傷害 PERCENT，0.00%~20.00%，每段 400 -->
	<series base="10000" name="最終傷害" stat="FINAL_DAMAGE_RATE" weight="100" valueType="PERCENT">
		<range from="0"    to="400"  weight="35" tier="5"/>
		<range from="401"  to="800"  weight="25" tier="4"/>
		<range from="801"  to="1200" weight="20" tier="3"/>
		<range from="1201" to="1600" weight="12" tier="2"/>
		<range from="1601" to="2000" weight="8"  tier="1"/>
	</series>

	<!-- 20000：最終減傷 PERCENT，0.00%~30.00%，每段 600 -->
	<series base="20000" name="最終減傷" stat="FINAL_DAMAGE_REDUCE" weight="100" valueType="PERCENT">
		<range from="0"    to="600"  weight="35" tier="5"/>
		<range from="601"  to="1200" weight="25" tier="4"/>
		<range from="1201" to="1800" weight="20" tier="3"/>
		<range from="1801" to="2400" weight="12" tier="2"/>
		<range from="2401" to="3000" weight="8"  tier="1"/>
	</series>

	<!-- 30000：無視最終減傷 PERCENT，0.00%~30.00%，每段 600 -->
