<?xml version="1.0" encoding="UTF-8"?>
<!--
	神匠強化系統配置
	series: 系列設定
		- name: 系列顯示名稱
		- id: 系列唯一識別碼
		- maxEnchant: 該系列的最大強化值
		- destroyChance: 強化失敗時裝備消失的機率 (0-100)
		- protectionItemId: 防爆道具ID (可選，若不設定則無法使用防爆道具)
	successRates: 強化成功率區間設定
		- range: 定義強化等級區間的成功率
			- min: 區間最小值
			- max: 區間最大值
			- rate: 該區間的成功率 (0-100)
		- 未設定的區間默認成功率為 5%
	slot: 裝備部位
		- type: 部位類型 (HEAD, CHEST, LEGS, GLOVES, FEET, BACK, BELT, RFINGER, LFINGER, REAR, LEAR, NECK)
		- itemIdMin/itemIdMax: 該系列該部位的道具ID範圍
	material: 可用的強化素材（可設定多個）
		- itemId: 素材道具ID
		- count: 所需素材數量
-->
<divineCraft>
	<series name="火龍系列" id="FireDragon" maxEnchant="100" destroyChance="15" protectionItemId="130002">
		<successRates>
			<range min="0" max="30" rate="70" />
			<range min="31" max="50" rate="50" />
			<range min="51" max="70" rate="30" />
			<range min="71" max="100" rate="10" />
		</successRates>
		<slot type="HEAD" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
		<slot type="CHEST" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
		<slot type="LEGS" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
		<slot type="GLOVES" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
		<slot type="FEET" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
		<slot type="BACK" itemIdMin="130000" itemIdMax="130100">
			<material itemId="130001" count="1" />
		</slot>
	</series>
	<series name="極神系列" id="GodOfLimit" maxEnchant="100" destroyChance="0" protectionItemId="57">
		<successRates>
			<range min="0" max="100" rate="50" />
		</successRates>
		<slot type="RHAND" itemIdMin="120000" itemIdMax="120064">
			<material itemId="98614" count="10" />
		</slot>
	</series>
	<!-- 新增系列範例：
	<series name="冰霜系列" id="frost" maxEnchant="50" destroyChance="30" protectionItemId="131200">
