<?xml version="1.0" encoding="UTF-8"?>
<!--
    祭祀系統配置文件 SacrificeData.xml
    =====================================================================
    結構：每個 altar 代表一座祭壇，包含消耗材料與屬性升級定義。

    altar 屬性：
        id            祭壇唯一 ID
        name          顯示名稱
        chancePercent 每次祭祀成功概率（1~100）
        upgradeRate   每級屬性增幅（0.10 = +10%/級）
        maxLevel      最高可升等級

    子元素：
        material itemId="道具ID" count="數量"   （每次祭祀消耗材料，可多個）
        stat name="屬性名" value="數值" operation="add 或 mul"

    ─── 屬性升級公式 ────────────────────────────────────────────────────
        value(Lv.N) = base × (1 + upgradeRate × (N − 1))

        例：base=500, upgradeRate=0.10, Lv.5
        → 500 × (1 + 0.10 × 4) = 500 × 1.40 = 700

    ─── operation 說明 ──────────────────────────────────────────────────
        add  固定數值加成，如 value="500"  → Lv.1 時 +500 物理攻擊
        mul  百分比乘算，  如 value="10"   → Lv.1 時 +10%（Lv.3 時 +12%）

    ─── 可用 stat name（支持英文或中文，與 TransformMorph.xml 完全一致）──
        英文                中文              說明
        pAtk           /  物理攻擊         物理攻擊力
        mAtk           /  魔法攻擊         魔法攻擊力
        pDef           /  物理防禦         物理防禦力
        mDef           /  魔法防禦         魔法防禦力
        pSkillPow      /  物理技能威力      物理技能傷害倍率
        mSkillPow      /  魔法技能威力      魔法技能傷害倍率
        atkSpd         /  攻擊速度         物理攻擊速度
        mAtkSpd        /  施法速度         魔法施法速度
        speed          /  移動速度         角色移動速度
        critRate       /  暴擊率           暴擊觸發率
        critDmg        /  暴擊傷害         暴擊傷害加成        (mul)
        mCritRate      /  魔法暴擊率        魔法暴擊觸發率
        mCritPower     /  魔法暴擊傷害     魔法暴擊傷害加成    (mul)
        maxHp          /  最大HP           最大生命值
        maxMp          /  最大MP           最大魔力值
        maxCp          /  最大CP           最大CP
        hpRegen        /  HP回復           生命值自然回復
        mpRegen        /  MP回復           魔力值自然回復
        cpRegen        /  CP回復           CP自然回復
        healEffect     /  治療效果增幅      治療技能效果（非藥水）
        healEffectadd  /  治療效果增加      治療技能固定加值（非藥水）
        additionalPotionHp  / 藥水HP加成   藥水/靈藥HP回覆固定加值
        additionalPotionMp  / 藥水MP加成   藥水/靈藥MP回覆固定加值
        additionalPotionCp  / 藥水CP加成   藥水/靈藥CP回覆固定加值
        additionalPotionHpPer / 藥水HP加成% 藥水/靈藥HP回覆百分比加成
        additionalPotionMpPer / 藥水MP加成% 藥水/靈藥MP回覆百分比加成
        additionalPotionCpPer / 藥水CP加成% 藥水/靈藥CP回覆百分比加成
        accuracy       /  命中              命中值
        evasion        /  閃避              閃避值
        str            /  力量              STR基礎屬性
        con            /  體質              CON基礎屬性
        dex            /  敏捷              DEX基礎屬性
        int            /  智力              INT基礎屬性
        wit            /  精神              WIT基礎屬性
        men            /  意志              MEN基礎屬性
        pvpPDmg        /  PVP物理傷害       PVP物理傷害加成    (mul)
        pvpMDmg        /  PVP魔法傷害       PVP魔法傷害加成    (mul)
        pvpPSkillDmg   /  PVP物理技能傷害   PVP物理技能加成    (mul)
        pvpPDef        /  PVP物理防禦        PVP物理防禦
        pvpMDef        /  PVP魔法防禦        PVP魔法防禦
        pvePDmg        /  PVE物理傷害        PVE物理傷害加成   (mul)
        pveMDmg        /  PVE魔法傷害        PVE魔法傷害加成   (mul)
        pvePSkillDmg   /  PVE物理技能傷害    PVE物理技能加成   (mul)
        fireAtk        /  火屬性攻擊         火元素攻擊力
        waterAtk       /  水屬性攻擊         水元素攻擊力
        windAtk        /  風屬性攻擊         風元素攻擊力
        earthAtk       /  土屬性攻擊         土元素攻擊力
        holyAtk        /  神聖攻擊           神聖元素攻擊力
        darkAtk        /  暗黑攻擊           暗黑元素攻擊力
        fireRes        /  火屬性抗性         火元素抗性
        waterRes       /  水屬性抗性         水元素抗性
        windRes        /  風屬性抗性         風元素抗性
        earthRes       /  土屬性抗性         土元素抗性
        holyRes        /  神聖抗性           神聖元素抗性
        darkRes        /  暗黑抗性           暗黑元素抗性
        expRate        /  經驗獲取            經驗獲取倍率     (mul)
        dropRate       /  掉落率              掉落率           (mul)
        dropAmount     /  掉落數量            掉落數量         (mul)
        spoilRate      /  採集率              採集率           (mul)
    ===================================================================== -->
<list xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../xsd/SacrificeData.xsd">
