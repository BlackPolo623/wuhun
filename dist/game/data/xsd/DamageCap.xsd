<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:element name="damagecap">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="pvp">
					<xs:complexType>
						<xs:attribute type="xs:double" name="soulring_bonus_per_ring" use="required" />
					</xs:complexType>
				</xs:element>
				<xs:element name="pve">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="monster" maxOccurs="unbounded" minOccurs="0">
								<xs:complexType>
									<xs:attribute type="xs:positiveInteger" name="id" use="required" />
									<xs:attribute type="xs:double" name="soulring_bonus_per_ring" use="required" />
								</xs:complexType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
</xs:schema>
